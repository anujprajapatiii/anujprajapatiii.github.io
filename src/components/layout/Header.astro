---
import { siteConfig } from "@/data/site-config";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header class="border-b border-border">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a href="/" class="font-mono text-sm font-medium tracking-wide transition-colors hover:text-accent">
      {siteConfig.name}
    </a>
    <div class="flex items-center gap-1">
      <nav aria-label="Main navigation" class="flex items-center gap-1">
        {siteConfig.nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class="rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground aria-[current=page]:text-foreground"
          >
            {item.label}
          </a>
        ))}
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>
