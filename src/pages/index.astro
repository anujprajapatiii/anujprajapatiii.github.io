---
import PageLayout from "@/layouts/PageLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { siteConfig } from "@/data/site-config";
import { getCollection } from "astro:content";

const featured = (await getCollection("projects", ({ data }) => !data.draft))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);
---

<PageLayout>
  {/* Hero — TODO(Anuj): replace with your own intro */}
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-12 sm:pt-24">
    <p class="mb-4 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Portfolio
    </p>
    <h1 class="text-4xl font-medium tracking-tight sm:text-5xl">
      {siteConfig.name}
    </h1>
    <p class="mt-4 max-w-xl text-lg text-muted-foreground">
      {siteConfig.description}
    </p>
  </section>

  {/* Featured work */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <div class="mb-8 flex items-baseline justify-between">
      <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
        Selected work
      </h2>
      <a
        href="/work"
        class="text-sm text-muted-foreground underline underline-offset-4 transition-colors hover:text-accent"
      >All work</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {featured.map((project) => (
        <ProjectCard
          id={project.id}
          title={project.data.title}
          description={project.data.description}
          role={project.data.role}
          year={project.data.year}
          thumbnail={project.data.thumbnail}
        />
      ))}
    </div>
  </section>
</PageLayout>
